<core:FragmentDefinition
  xmlns:core="sap.ui.core"
  xmlns:f="sap.ui.layout.form"
  xmlns="sap.m">

  <Dialog title="Add New Product" class="addProductDialog" contentWidth="26rem">
    <content>
      <f:SimpleForm editable="true" layout="ResponsiveGridLayout">
        <Label text="Product Name" required="true"/>
        <Input value="{newProduct>/ProductName}" placeholder="e.g. Chai Tea"/>

        <Label text="Quantity Per Unit"/>
        <Input value="{newProduct>/QuantityPerUnit}" placeholder="e.g. 10 boxes x 20 bags"/>

        <Label text="Unit Price"/>
        <Input value="{newProduct>/UnitPrice}" type="Number" placeholder="0.00"/>

        <Label text="Units In Stock"/>
        <Input value="{newProduct>/UnitsInStock}" type="Number" placeholder="0"/>
      </f:SimpleForm>
    </content>
    <beginButton>
      <Button text="Save" type="Emphasized" press=".onSaveNewProduct"/>
    </beginButton>
    <endButton>
      <Button text="Cancel" press=".onCancelNewProduct"/>
    </endButton>
  </Dialog>

</core:FragmentDefinition>
